# Copy to `.env` and adjust as needed. All values have sane defaults for local
# testing, so an empty/absent .env still works.

# Host port the gateway (and therefore the whole app) is published on.
PORT=8080

# JWT signing key used by the backend. Change this for any non-local use.
AUTH_KEY=frontier-dev-only-change-me-to-a-long-random-secret-0123456789

# Backend CORS. Empty = allow any origin (fine behind the gateway / for the demo).
# To lock down, set a comma-separated list, e.g.:
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=
